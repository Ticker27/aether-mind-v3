<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="12dp"
    android:background="@drawable/ghost_panel_bg" android:alpha="0.92">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Auto-Play Control" android:textSize="16sp" android:textColor="#ff4444"
        android:textStyle="bold" android:layout_marginBottom="12dp" />

    <!-- Master Auto-Play Switch -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Auto-Play Master" android:textSize="12sp"
            android:textColor="#ffffff" />
        <Switch android:id="@+id/sw_autoplay_master" android:layout_width="wrap_content"
            android:layout_height="24dp" android:checked="false" />
    </LinearLayout>

    <!-- Auto-Aim Switch -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Auto-Aim" android:textSize="12sp"
            android:textColor="#ffffff" />
        <Switch android:id="@+id/sw_auto_aim" android:layout_width="wrap_content"
            android:layout_height="24dp" android:checked="true" />
    </LinearLayout>

    <!-- Auto-Shoot Switch -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Auto-Shoot" android:textSize="12sp"
            android:textColor="#ffffff" />
        <Switch android:id="@+id/sw_auto_shoot" android:layout_width="wrap_content"
            android:layout_height="24dp" android:checked="true" />
    </LinearLayout>

    <!-- Hide Guideline Switch -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Hide Guideline" android:textSize="12sp"
            android:textColor="#ffffff" />
        <Switch android:id="@+id/sw_hide_guideline" android:layout_width="wrap_content"
            android:layout_height="24dp" android:checked="true" />
    </LinearLayout>

    <!-- Skill Slider -->
    <TextView android:id="@+id/tv_skill" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="AI Skill: 88%" android:textSize="10sp"
        android:textColor="#ffffff" android:layout_marginBottom="4dp" />
    <SeekBar android:id="@+id/sb_skill" android:layout_width="match_parent"
        android:layout_height="24dp" android:max="100" android:progress="88"
        android:layout_marginBottom="12dp" />

    <!-- Delay Slider (Think Time) -->
    <TextView android:id="@+id/tv_delay" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="Think Delay: 1.5s" android:textSize="10sp"
        android:textColor="#ffffff" android:layout_marginBottom="4dp" />
    <SeekBar android:id="@+id/sb_delay" android:layout_width="match_parent"
        android:layout_height="24dp" android:max="50" android:progress="15"
        android:layout_marginBottom="12dp" />

    <!-- Buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="8dp">
        <Button android:id="@+id/btn_launch_game" android:layout_width="0dp"
            android:layout_height="36dp" android:layout_weight="1" android:text="🎱 Game"
            android:textSize="10sp" android:backgroundTint="#2196F3" android:textColor="#ffffff"
            android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btn_force_shoot" android:layout_width="0dp"
            android:layout_height="36dp" android:layout_weight="1" android:text="⚡ Shoot Now"
            android:textSize="10sp" android:backgroundTint="#FF9800" android:textColor="#ffffff" />
    </LinearLayout>

    <Button android:id="@+id/btn_hide" android:layout_width="match_parent"
        android:layout_height="32dp" android:text="Hide Panel" android:textSize="10sp"
        android:backgroundTint="#555555" android:textColor="#ffffff" />
</LinearLayout>
