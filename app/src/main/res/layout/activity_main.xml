<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#00000000">
    <LinearLayout android:layout_width="280dp" android:layout_height="wrap_content"
        android:layout_gravity="center" android:orientation="vertical"
        android:padding="24dp" android:background="@drawable/ghost_panel_bg" android:alpha="0.92">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Project Aether" android:textSize="24sp" android:textColor="#ff4444"
            android:textStyle="bold" android:layout_gravity="center" android:layout_marginBottom="4dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Auto-Play Ghost v4.0" android:textSize="12sp" android:textColor="#888888"
            android:layout_gravity="center" android:layout_marginBottom="24dp" />
        <EditText android:id="@+id/et_license" android:layout_width="match_parent"
            android:layout_height="48dp" android:hint="License Key" android:textColor="#ffffff"
            android:textColorHint="#666666" android:background="@drawable/edit_bg"
            android:padding="12dp" android:inputType="textPassword" android:layout_marginBottom="16dp" />
        <Button android:id="@+id/btn_activate" android:layout_width="match_parent"
            android:layout_height="48dp" android:text="Activate Auto-Play"
            android:textSize="14sp" android:backgroundTint="#ff4444" android:textColor="#ffffff"
            android:layout_marginBottom="8dp" />
        <TextView android:id="@+id/status_text" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="● Inactive"
            android:textSize="12sp" android:textColor="#888888" android:layout_gravity="center" />
    </LinearLayout>
</FrameLayout>
